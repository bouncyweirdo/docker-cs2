# CS2 server configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: get a token at https://steamcommunity.com/dev/managegameservers (app ID 730)
SRCDS_TOKEN=

# Server settings
CS2_SERVERNAME=My CS2 Server
CS2_PORT=27015
CS2_PW=
CS2_RCONPW=
CS2_MAXPLAYERS=10
CS2_LAN=0
CS2_CHEATS=0
CS2_UPDATE=1

# Game settings
# Game type: 0=standard, 1=deathmatch
CS2_GAMETYPE=0
# Game mode: 0=casual, 1=competitive, 2=wingman (when gametype=1: 2=deathmatch)
CS2_GAMEMODE=1
CS2_MAPGROUP=mg_active
CS2_STARTMAP=de_dust2
CS2_FREEZETIME=15
